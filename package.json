{
  "name": "@lud/pm",
  "version": "0.2.1",
  "type": "module",
  "bin": {
    "pm": "dist/main.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx src/main.ts",
    "typecheck": "tsc --noEmit",
