{
  "name": "@lud/pm",
  "version": "0.5.0",
  "type": "module",
  "bin": {
    "pm": "dist/main.js"
  },
  "description": "File-based project management CLI for software developers working with AI coding assistants",
  "repository": {
    "type": "git",
    "url": "https://github.com/lud/pm.git"
  },
  "homepage": "https://github.com/lud/pm",
  "bugs": "https://github.com/lud/pm/issues",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx src/main.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc && node tools/add-shebang.cjs dist/main.js",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "ansis": "^4.2.0",
    "cleye": "^2.2.1",
    "text-table": "^0.2.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@types/text-table": "^0.2.5",
    "@vitest/coverage-v8": "^4.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
